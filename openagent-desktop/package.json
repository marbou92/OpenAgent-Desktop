{
  "name": "openagent-desktop",
  "version": "1.0.0",
  "description": "Open-source desktop AI agent with VM-level sandboxing, 35+ providers, 60+ extensions, recipe system, and ACP protocol support",
  "main": "dist/electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/marbou92/OpenAgent-Desktop.git"
  },
  "homepage": "https://github.com/marbou92/OpenAgent-Desktop",
  "bugs": {
    "url": "https://github.com/marbou92/OpenAgent-Desktop/issues"
  },
  "author": "marbou92",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && npm run build:electron && electron-builder",
    "electron:build:win": "npm run build && npm run build:electron && electron-builder --win",
    "electron:build:mac": "npm run build && npm run build:electron && electron-builder --mac",
    "electron:build:linux": "npm run build && npm run build:electron && electron-builder --linux",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Tests not yet implemented\" && exit 0",
    "clean": "rimraf dist dist-electron release"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.5.0",
    "remark-gfm": "^4.0.0",
    "rehype-raw": "^7.0.0",
    "lucide-react": "^0.344.0",
    "zustand": "^4.5.0",
    "eventsource-parser": "^1.1.2",
    "uuid": "^9.0.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "chokidar": "^3.6.0",
    "js-yaml": "^4.1.0",
    "dotenv": "^16.4.1",
    "node-fetch": "^3.3.2",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@types/uuid": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "eslint": "8.57.1",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "4.6.2",
    "postcss": "^8.4.33",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.1",
    "typescript": "5.6.3",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.openagent.desktop",
    "productName": "OpenAgent-Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "marbou92",
      "repo": "OpenAgent-Desktop"
    }
  }
}
